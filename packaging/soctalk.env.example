# SocTalk unattended-install environment.
#
# For a non-interactive install, set these and run:
#     sudo -E soctalk install --skip-consent
# (or `soctalk install --demo` for a throwaway demo with a random admin password).
#
# The installer reads these the same way `curl … | bash` does. Only the LLM
# provider + key and the MSSP identity are required for a real install.

# --- MSSP identity + bootstrap admin ---
export SOCTALK_MSSP_NAME="Acme Security"
export SOCTALK_ADMIN_EMAIL="ops@acme.example"
# export SOCTALK_ADMIN_PASSWORD="change-me-min-12-chars"   # omit for --demo (random)

# --- LLM provider (anthropic | openai | openai-compatible) ---
export SOCTALK_LLM_PROVIDER="anthropic"
export SOCTALK_LLM_API_KEY="sk-..."

# --- Optional overrides ---
# export SOCTALK_HOSTNAME="soctalk.acme.example"   # ingress FQDN (default: box IP)
# export SOCTALK_CHART_VERSION="0.2.0"             # pin the chart (default: tracks the package)
# export SOCTALK_IMAGE_TAG="0.2.0"                 # pin images (default: chart version)
