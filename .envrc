use flake . --impure

# Project-local kubeconfig. Any ``k3d cluster create`` /
# ``helm install`` / ``kubectl ...`` run from inside this directory
# writes here, leaving ~/.kube/config untouched. See CONTRIBUTING.md
# "Project-local Kubernetes config" for the rationale.
mkdir -p .kube
[ -f .kube/config ] || touch .kube/config
export KUBECONFIG=$PWD/.kube/config
